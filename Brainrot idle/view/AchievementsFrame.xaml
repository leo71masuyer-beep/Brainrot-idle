<Page x:Class="Brainrot_idle.view.AchievementsFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AchievementsFrame">

    <Grid Background="#090014">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" 
                Content="FERMER" 
                Width="100" Height="30" 
                Margin="20,15,0,0" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top"
                Background="Transparent" 
                Foreground="#CCFF00" 
                BorderBrush="#7A00FF" 
                BorderThickness="2" 
                FontWeight="Bold" 
                Click="Close_Button_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <TextBlock Grid.Row="0" Text="SUCCÈS DÉBLOQUÉS" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <WrapPanel x:Name="ConteneurSucces" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </ScrollViewer>

    </Grid>
</Page>
