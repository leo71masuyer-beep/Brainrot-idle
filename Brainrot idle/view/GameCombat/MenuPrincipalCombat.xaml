                                    <TextBlock x:Name="Txtudindindindun" Text="0/1" Foreground="#00FF40" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Canvas.Left="850" Canvas.Top="2850" Width="70">
                                    <Button x:Name="Btnpatapim" ToolTip="chance de cout critique + 5%" Width="70" Height="70" Cursor="Hand" Background="#111" Click="Btnpatapim_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bordurepatapim" BorderBrush="#333333" BorderThickness="3" CornerRadius="35">
                                                    <Border.Background>
