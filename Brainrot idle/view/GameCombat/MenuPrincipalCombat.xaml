                                </StackPanel>

                                <StackPanel Canvas.Left="1500" Canvas.Top="1950" Width="70">
                                    <Button x:Name="BtnSigmaAura" ToolTip="aura +20%" Width="70" Height="70" Cursor="Hand" Background="#111" Click="BtnSigmaAura_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BordureSigmaAura" BorderBrush="#333333" BorderThickness="3" CornerRadius="35">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="pack://application:,,,/view/GameCombat/Ressources/SuperAura.jpg" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Sigma Aura" TextWrapping="Wrap" TextAlignment="Center" Foreground="#D0C0E0" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Prix : 3 Pierres" Foreground="#FFD700" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSigmaAura" Text="0/1" Foreground="#00FF40" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Canvas.Left="1300" Canvas.Top="2150" Width="70">
