                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="Super Aura" TextWrapping="Wrap" TextAlignment="Center" Foreground="#D0C0E0" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
