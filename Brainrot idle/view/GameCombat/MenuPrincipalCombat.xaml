<Page x:Class="Brainrot_idle.view.GameCombat.MenuPrincipalCombat"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Menu Principal Combat" Background="#0A0410"
      Loaded="Page_Loaded">

    <!-- Grille principale -->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- EN-TÊTE GAUCHE : Avatar, Nom, Niveau, XP   -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Margin="0,0,10,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="50" Height="50" Background="#2A004D" BorderBrush="#9D00FF" BorderThickness="2" CornerRadius="5">
                    <TextBlock Text="🪵" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-5"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="TUNG TUNG SAHUR" Foreground="White" FontWeight="Bold" FontSize="16" />
                    <TextBlock x:Name="TxtNiveauGlobal" Text="NIVEAU 1" Foreground="#00FF40" FontSize="12" FontWeight="Bold" Margin="0,2,0,5"/>

                    <Grid>
                        <ProgressBar x:Name="BarreXpGlobal" Value="0" Maximum="50" Height="8" Background="#0A0410" BorderBrush="#9D00FF" Foreground="#00FF40"/>
                        <TextBlock x:Name="TxtXpGlobal" Text="0 / 50" Foreground="#D0C0E0" FontSize="10" HorizontalAlignment="Right" Margin="0,-12,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- EN-TÊTE DROITE : Ressources et Retour      -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Margin="0,0,0,10">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="🪙" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtOrGlobal" Text="0" Foreground="#00FF40" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>

                    <TextBlock Text="🪨" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtPierreGlobal" Text="0" Foreground="#00FF40" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>

                    <TextBlock Text="💎" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtDiamantGlobal" Text="0" Foreground="#00FF40" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnRetour" Content="⬅ RETOUR" Background="#2A004D" Foreground="White" 
                        BorderBrush="#9D00FF" BorderThickness="2" FontWeight="Bold" Padding="15,8" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                        Click="BtnRetour_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- PANNEAU GAUCHE BAS : Portrait ET JOUER     -->
        <!-- ========================================== -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="TUNG TUNG SAHUR" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,20,0,15" />

                <Border BorderBrush="#9D00FF" BorderThickness="2" Margin="15,0,15,15" Height="220" CornerRadius="8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4A00E0" Offset="0.0"/>
                            <GradientStop Color="#8E2DE2" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🪵" FontSize="140" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-15"/>
                </Border>

                <Border Height="2" Background="#9D00FF" Margin="15,0,15,15"/>

                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="DIFFICULTÉ" Foreground="#D0C0E0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboDifficulte" Width="180" Height="30" Margin="0,0,0,15" FontSize="14" Background="#2A004D" Foreground="Black">
                        <ComboBoxItem Content="Facile" IsSelected="True"/>
                        <ComboBoxItem Content="Moyen"/>
                        <ComboBoxItem Content="Difficile"/>
                    </ComboBox>

                    <Button x:Name="BtnStartCombat" Content="START" Width="180" Height="50" Background="#9D00FF" Foreground="White" FontSize="20" FontWeight="Bold" Cursor="Hand" Click="BtnStartCombat_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ========================================== -->
        <!-- PANNEAU DROIT BAS : Onglets et Contenu     -->
        <!-- ========================================== -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0,0,0">
                <Button x:Name="BtnOngletStats" Click="BtnOngletStats_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,5,0">
                    <Border x:Name="FondOngletStats" Background="#2A004D" BorderBrush="#9D00FF" BorderThickness="3,3,3,0" Padding="30,10" CornerRadius="10,10,0,0">
                        <TextBlock x:Name="TexteOngletStats" Text="STATISTIQUES" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Button>

                <Button x:Name="BtnOngletArbre" Click="BtnOngletArbre_Click" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,5,0">
                    <Border x:Name="FondOngletArbre" Background="#0A0410" BorderBrush="#4D0099" BorderThickness="3,3,3,0" Padding="30,10" CornerRadius="10,10,0,0">
                        <TextBlock x:Name="TexteOngletArbre" Text="ARBRE DE COMPÉTENCES" Foreground="#A080C0" FontWeight="Bold"/>
                    </Border>
                </Button>

                <Button x:Name="BtnOngletGacha" Click="BtnOngletGacha_Click" Background="Transparent" BorderThickness="0" Padding="0">
                    <Border x:Name="FondOngletGacha" Background="#0A0410" BorderBrush="#4D0099" BorderThickness="3,3,3,0" Padding="30,10" CornerRadius="10,10,0,0">
                        <TextBlock x:Name="TexteOngletGacha" Text="TIRAGE GACHA" Foreground="#A080C0" FontWeight="Bold"/>
                    </Border>
                </Button>
            </StackPanel>

            <Border Grid.Row="1" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Padding="20">
