                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bordureudindindindun" BorderBrush="#333333" BorderThickness="3" CornerRadius="35">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="pack://application:,,,/view/GameCombat/Ressources/sahur.jpg" Stretch="UniformToFill"/>
