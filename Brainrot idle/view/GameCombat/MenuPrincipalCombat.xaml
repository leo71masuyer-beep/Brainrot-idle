                                <StackPanel Canvas.Left="1500" Canvas.Top="1500" Width="70">
                                    <Button x:Name="BtnCompBase" ToolTip="atk +10" Width="70" Height="70" Cursor="Hand" Background="#111" Click="BtnCompBase_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BordureBase" BorderBrush="Gold" BorderThickness="3" CornerRadius="35" Background="#1A1A1A">
