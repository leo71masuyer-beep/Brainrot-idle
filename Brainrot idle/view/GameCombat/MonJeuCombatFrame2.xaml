<Page x:Class="Brainrot_idle.view.MonJeuCombatFrame2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Combat" Background="Black">

    <Grid>
        <Image Source="pack://application:,,,/view/GameCombat/Ressources/background/bar_background.png" Stretch="UniformToFill"/>
        <Rectangle Fill="#60000000"/>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="2.5*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Left">
                    <StackPanel Width="300">
                        <TextBlock x:Name="TxtNomHeros" Text="Tung Tung Sahur" Foreground="White" FontWeight="Bold" FontFamily="Consolas"/>
                        <ProgressBar x:Name="BarrePVHeros" Height="25" Foreground="#4CAF50" Background="#333" Maximum="100" Value="100"/>
                        <TextBlock x:Name="TxtStatsHeros" Text="PV: 100/100" Foreground="White" FontFamily="Consolas"/>
                    </StackPanel>
                </Viewbox>

                <Viewbox Grid.Column="1" Stretch="Uniform">
                    <TextBlock Text="VS" Foreground="#FFD700" FontWeight="Bold" FontFamily="Consolas" Margin="10"/>
                </Viewbox>

                <Viewbox Grid.Column="2" Stretch="Uniform" HorizontalAlignment="Right">
                    <StackPanel Width="300">
                        <TextBlock x:Name="TxtNomEnnemi" Text="Ennemi" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" FontFamily="Consolas"/>
                        <ProgressBar x:Name="BarrePVEnnemi" Height="25" Foreground="#F44336" Background="#333" Maximum="50" Value="50" FlowDirection="RightToLeft"/>
                        <TextBlock x:Name="TxtStatsEnnemi" Text="PV: 50/50" Foreground="White" HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </StackPanel>
                </Viewbox>
            </Grid>

            <Grid Grid.Row="1" Margin="10,118,-10,108" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Stretch="Uniform">
                    <Image x:Name="ImgHeros" Source="pack://application:,,,/view/GameCombat/Ressources/Sprites/heros_idle.png" Height="300"/>
                </Viewbox>

                <Viewbox Grid.Column="1" Stretch="Uniform">
                    <Image x:Name="ImgEnnemi" Source="pack://application:,,,/view/GameCombat/Ressources/Sprites/lutin_basique.png" Height="300"/>
                </Viewbox>
            </Grid>

            <Border Grid.Row="2" Background="#80000000" CornerRadius="5" Margin="0,10,0,0">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Récompenses actuelles : " Foreground="#A59C90" FontFamily="Consolas"/>
                            <TextBlock x:Name="TxtOrGagne" Text="0 Or" Foreground="#FFD700" FontWeight="Bold" FontFamily="Consolas" Margin="20,0"/>
                            <TextBlock x:Name="TxtExpGagne" Text="0 Exp" Foreground="#4CAF50" FontWeight="Bold" FontFamily="Consolas" Margin="20,0"/>
                        </StackPanel>
                    </Viewbox>

                    <Viewbox Grid.Column="1" Stretch="Uniform">
                        <Button x:Name="BtnArreterCombat" Content="FUIR &amp; LOOTER" 
                                Background="#8B0000" Foreground="White" FontWeight="Bold" FontFamily="Consolas"
                                Padding="30,15" Cursor="Hand" Click="BtnArreterCombat_Click"/>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>