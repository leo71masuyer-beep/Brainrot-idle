<Page x:Class="Brainrot_idle.view.MonJeuCombatFrame2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Combat" Background="Black">

    <Grid>
        <!-- Arrière-plan -->
        <Image Source="pack://application:,,,/view/GameCombat/Ressources/background/gigachad_background.png" Stretch="UniformToFill"/>
        <Rectangle Fill="#40000000"/>
        <!-- Légèrement éclairci pour mieux voir le fond -->

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- S'adapte à la taille exacte des barres de vie -->
                <RowDefinition Height="*"/>
                <!-- Prend tout l'espace libre au milieu -->
                <RowDefinition Height="Auto"/>
                <!-- S'adapte à la taille exacte du menu du bas -->
            </Grid.RowDefinitions>

            <!-- LIGNE 0 : BARRES DE VIE -->
            <Grid Grid.Row="0" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Héros -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Left" Width="350">
                    <TextBlock x:Name="TxtNomHeros" Text="Tung Tung Sahur" Foreground="White" FontSize="22" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="BarrePVHeros" Height="25" Foreground="#4CAF50" Background="#333333" Maximum="100" Value="79" BorderThickness="1" BorderBrush="#555"/>
                    <TextBlock x:Name="TxtStatsHeros" Text="PV: 100 / 100" Foreground="White" FontSize="16" FontFamily="Consolas" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- VS -->
                <TextBlock Grid.Column="1" Text="VS" Foreground="#FFD700" FontSize="36" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" Margin="30,0"/>

                <!-- Ennemi -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Width="350">
                    <TextBlock x:Name="TxtNomEnnemi" Text="gigachad" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" FontFamily="Consolas" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="BarrePVEnnemi" Height="25" Foreground="#F44336" Background="#333333" Maximum="1000" Value="978" FlowDirection="RightToLeft" BorderThickness="1" BorderBrush="#555"/>
                    <TextBlock x:Name="TxtStatsEnnemi" Text="PV: 1000 / 1000" Foreground="White" FontSize="16" HorizontalAlignment="Right" FontFamily="Consolas" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- LIGNE 1 : PERSONNAGES -->
            <!-- Le fond de cette ligne descend maintenant beaucoup plus bas sur l'image -->
            <Grid Grid.Row="1" Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="ImgHeros" Grid.Column="0" Source="pack://application:,,,/view/GameCombat/Ressources/Sprites/heros_idle.png" 
                       Stretch="Uniform" Height="300" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Image x:Name="ImgEnnemi" Grid.Column="1" Source="pack://application:,,,/view/GameCombat/Ressources/Sprites/gigachad_idle.png" 
                       Stretch="Uniform" Height="350" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            </Grid>

            <Border Grid.Row="2" Background="#E60A0A0A" CornerRadius="10" Margin="0,15,0,0" BorderBrush="#44FFFFFF" BorderThickness="1">
                <Grid Margin="25,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="RÉCOMPENSES :" Foreground="#A59C90" FontSize="22" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtOrGagne" Text="0 Or" Foreground="#FFD700" FontSize="26" FontWeight="Bold" FontFamily="Consolas" Margin="30,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtExpGagne" Text="0 Exp" Foreground="#4CAF50" FontSize="26" FontWeight="Bold" FontFamily="Consolas" Margin="30,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1" x:Name="BtnArreterCombat" Content="FUIR &amp; LOOTER" 
                            Background="#990000" Foreground="White" FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                            Padding="40,15" Cursor="Hand" Click="BtnArreterCombat_Click" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>