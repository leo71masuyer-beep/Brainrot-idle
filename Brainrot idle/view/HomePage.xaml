<Page x:Class="Brainrot_idle.view.HomePage" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Brainrot_idle.view"
        mc:Ignorable="d">
    <!-- Grille principale -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="950"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Seconde grille -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="1" Grid.Column="0" Content="Mini jeu" Click="MiniGames_Button_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="Button 2"/>
            <Button Grid.Row="1" Grid.Column="2" Content="Button 3"/>
            <Button Grid.Row="1" Grid.Column="3" Content="Button 4"/>
            <Button Grid.Row="1" Grid.Column="4" Content="Button 5"/>
            <Button Grid.Row="1" Grid.Column="5" Content="Paramètre" Click="Parametre_Button_Click"/>
        </Grid>
        <Button Grid.Row="0" Grid.Column="0" Content="Aura" Margin="500,400,500,200" Click="AuraButton_Click"/>
        <Label x:Name="AuraPoints" Content="AuraPoints :" HorizontalAlignment="Center" Margin="0,275,0,0" VerticalAlignment="Top"/>
        <Label x:Name="AuraPointsParSec" Content="Points/seconde : 0" HorizontalAlignment="Center" Margin="0,0,1300,0" VerticalAlignment="Top"/>
        <ScrollViewer Grid.Row="0"
              Grid.Column="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
            <Canvas Width="2000" Height="2000" Background="LightGray">
                <StackPanel Canvas.Left="0" Canvas.Top="50" Margin="10,0,0,0">
                    <!--amélio 1 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 10" Width="140"/>
                        <Button x:Name="Amelioration1" Width="100" Height="40" Content="Amélioration 1" Click="Amelioration1_Click"/>
                        <Label x:Name="NbAmelioration1" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 2 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 100" Width="140"/>
                        <Button x:Name="Amelioration2" Width="100" Height="40" Content="Amélioration 2" Click="Amelioration2_Click"/>
                        <Label x:Name="NbAmelioration2" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 3 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 1K" Width="140"/>
                        <Button x:Name="Amelioration3" Width="100" Height="40" Content="Amélioration 3" Click="Amelioration3_Click"/>
                        <Label x:Name="NbAmelioration3" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 4 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 10K" Width="140"/>
                        <Button x:Name="Amelioration4" Width="100" Height="40" Content="Amélioration 4" Click="Amelioration4_Click"/>
                        <Label x:Name="NbAmelioration4" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 5 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 100K" Width="140"/>
                        <Button x:Name="Amelioration5" Width="100" Height="40" Content="Amélioration 5" Click="Amelioration5_Click"/>
                        <Label x:Name="NbAmelioration5" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 6 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 1M" Width="140"/>
                        <Button x:Name="Amelioration6" Width="100" Height="40" Content="Amélioration 6" Click="Amelioration6_Click"/>
                        <Label x:Name="NbAmelioration6" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 7-->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 10M" Width="140"/>
                        <Button x:Name="Amelioration7" Width="100" Height="40" Content="Amélioration 7" Click="Amelioration7_Click"/>
                        <Label x:Name="NbAmelioration7" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 8 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 100M" Width="140"/>
                        <Button x:Name="Amelioration8" Width="100" Height="40" Content="Amélioration 8" Click="Amelioration8_Click"/>
                        <Label x:Name="NbAmelioration8" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 9 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 1T" Width="140"/>
                        <Button x:Name="Amelioration9" Width="100" Height="40" Content="Amélioration 9" Click="Amelioration9_Click"/>
                        <Label x:Name="NbAmelioration9" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                    <!--amélio 10 -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,5">
                        <Label Content="prix : 10T" Width="140"/>
                        <Button x:Name="Amelioration10" Width="100" Height="40" Content="Amélioration 10" Click="Amelioration10_Click"/>
                        <Label x:Name="NbAmelioration10" Content="Possédé : 0" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Canvas>
        </ScrollViewer>
    </Grid>
</Page>
