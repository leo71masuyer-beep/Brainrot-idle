<Window x:Class="Brainrot_idle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brainrot Idle" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

        <Border x:Name="TutoPopup" 
                Width="350" Height="180" 
                Background="#120020" BorderBrush="#7A00FF" BorderThickness="3" 
                CornerRadius="15" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#7A00FF" BlurRadius="15" ShadowDepth="0"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TutoTitleText" Grid.Row="0" 
                           Text="TUTORIEL (1/3)" Foreground="#B6FF00" 
                           FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>

                <TextBlock x:Name="TutoContentText" Grid.Row="1" 
                           Text="Bienvenue dans Brainrot Idle ! Clique sur le bouton au centre pour commencer à accumuler de l'Aura." 
                           Foreground="White" FontSize="14" TextWrapping="Wrap" 
                           TextAlignment="Center" VerticalAlignment="Center" Margin="0,5"/>

                <Button Grid.Row="2" x:Name="TutoButton" Content="OK, j'ai compris !" 
                        Width="140" Height="32" Background="#1F102E" Foreground="#B6FF00" 
                        BorderBrush="#7A00FF" FontWeight="Bold" Cursor="Hand"
                        Click="TutoButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>