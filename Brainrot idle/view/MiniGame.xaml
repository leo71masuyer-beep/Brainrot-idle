<Window x:Class="Brainrot_idle.view.MiniGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Brainrot_idle.view"
        mc:Ignorable="d"
        Title="MiniGame" Height="450" Width="800">
    <Grid>
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="1" Grid.Column="0" Content="Button 1" Margin="5,5"/>
            <Button Grid.Row="1" Grid.Column="1" Content="Button 2" Margin="5,5"/>
            <Button Grid.Row="1" Grid.Column="2" Content="Button 3" Margin="5,5"/>
            <Button Grid.Row="1" Grid.Column="3" Content="Button 4" Margin="5,5"/>
            
            <Button Grid.Row="0" Grid.Column="0" Content="Button 7" Margin="5,5"/>
            <Button Grid.Row="0" Grid.Column="1" Content="Button 8" Margin="5,5"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Button 9" Margin="5,5"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Button 10" Margin="5,5"/>
            
        </Grid>
    </Grid>
</Window>
