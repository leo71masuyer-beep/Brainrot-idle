<Page x:Class="Brainrot_idle.view.MiniGamesFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d"
      Title="MiniGamesFrame"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="GameButtonStyle" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="#120524" BorderBrush="#9D00FF" BorderThickness="3" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A004D"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#00FF40"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A00E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#0A0410" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Margin="5,5,5,15">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← FERMER" Background="#2A004D" Foreground="White" 
                        BorderBrush="#9D00FF" BorderThickness="2" FontWeight="Bold" Padding="15,8" 
                        VerticalAlignment="Center" Cursor="Hand"
                        Click="Close_Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Grid.Column="1" Text="SÉLECTION DES MINI-JEUX" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="0,0,100,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Margin="10">
                <Button x:Name="SnakeButton" Content="SNAKE" Style="{StaticResource GameButtonStyle}" Click="Snake_Button_Click"/>
                <Image x:Name="SnakeLockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="1" Margin="10">
                <Button x:Name="CombatButton" Content="COMBAT" Style="{StaticResource GameButtonStyle}" Click="Combat_Button_Click"/>
                <Image x:Name="CombatLockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="2" Margin="10">
                <Button x:Name="MorpionButton" Content="MORPION" Style="{StaticResource GameButtonStyle}" Click="Morpion_Button_Click"/>
                <Image x:Name="MorpionLockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="3" Margin="10">
                <Button x:Name="Jeu4Button" Content="MINI JEU 4" Style="{StaticResource GameButtonStyle}" Click="Jeu4_Button_Click"/>
                <Image x:Name="Jeu4LockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="0" Margin="10">
                <Button x:Name="Jeu5Button" Content="MINI JEU 5" Style="{StaticResource GameButtonStyle}" Click="Jeu5_Button_Click"/>
                <Image x:Name="Jeu5LockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1" Margin="10">
                <Button x:Name="Jeu6Button" Content="MINI JEU 6" Style="{StaticResource GameButtonStyle}" Click="Jeu6_Button_Click"/>
                <Image x:Name="Jeu6LockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="2" Margin="10">
                <Button x:Name="Jeu7Button" Content="MINI JEU 7" Style="{StaticResource GameButtonStyle}" Click="Jeu7_Button_Click"/>
                <Image x:Name="Jeu7LockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="3" Margin="10">
                <Button x:Name="Jeu8Button" Content="MINI JEU 8" Style="{StaticResource GameButtonStyle}" Click="Jeu8_Button_Click"/>
                <Image x:Name="Jeu8LockImage" Source="pack://application:,,,/Ressources/image/chaine.png" Margin="25" IsHitTestVisible="False" Panel.ZIndex="1"/>
            </Grid>
        </Grid>
    </Grid>
</Page>