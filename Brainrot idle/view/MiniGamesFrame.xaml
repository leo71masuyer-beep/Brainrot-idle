<Page x:Class="Brainrot_idle.view.MiniGamesFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Brainrot_idle.view"
        mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Grid.Column="3" Content="Fermer" Margin="100,5,5,5" Click="Close_Button_Click"/>
        <Button Grid.Row="1" Grid.Column="0" Content="Snake" Margin="5,5" Click="Snake_Button_Click"/>
        <Button Grid.Row="1" Grid.Column="1" Content="combat" Margin="5,5" Click="Combat_Button_Click"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Button 3" Margin="5,5"/>
        <Button Grid.Row="1" Grid.Column="3" Content="Button 4" Margin="5,5"/>
        <Button Grid.Row="2" Grid.Column="0" Content="Button 5" Margin="5,5"/>
        <Button Grid.Row="2" Grid.Column="1" Content="Button 6" Margin="5,5"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Button 7" Margin="5,5"/>
        <Button Grid.Row="2" Grid.Column="3" Content="Button 8" Margin="5,5"/>
    </Grid>
</Page>
