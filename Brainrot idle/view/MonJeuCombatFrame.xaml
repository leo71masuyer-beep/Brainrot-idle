<Page x:Class="Brainrot_idle.view.MonJeuCombatFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Brainrot_idle.view"
        mc:Ignorable="d"
        Title="MonJeuCombatFrame" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtVague" Text="Niveau 1 - Vague 1" 
           HorizontalAlignment="Center" FontSize="24" Margin="10"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <StackPanel VerticalAlignment="Center" Margin="20">
                <TextBlock x:Name="TxtNomHeros" Text="Ton Héros" HorizontalAlignment="Center" FontWeight="Bold"/>
                <ProgressBar x:Name="BarrePVHeros" Height="20" Foreground="Green" Maximum="100" Value="100"/>
                <TextBlock x:Name="TxtStatsHeros" Text="PV: 100/100" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Center" Margin="20">
                <TextBlock x:Name="TxtNomEnnemi" Text="Ennemi" HorizontalAlignment="Center" FontWeight="Bold"/>
                <ProgressBar x:Name="BarrePVEnnemi" Height="20" Foreground="Red" Maximum="50" Value="50"/>
                <TextBlock x:Name="TxtStatsEnnemi" Text="PV: 50/50" HorizontalAlignment="Center"/>
            </StackPanel>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="BtnAttaque" Content="ATTAQUER" Width="120" Height="40" Margin="10" Click="BtnAttaque_Click"/>
            <Button x:Name="BtnCompetence" Content="COMPÉTENCES" Width="120" Height="40" Margin="10"/>
        </StackPanel>
    </Grid>
</Page>
