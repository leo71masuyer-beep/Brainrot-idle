<Page x:Class="Brainrot_idle.view.MorpionFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MorpionFrame">

    <DockPanel Margin="20">

        <StackPanel DockPanel.Dock="Top"
            Margin="0,0,0,20">

            <Button x:Name="ReturnButton"
            Content="← Retour"
            Width="120"
            Height="35"
            HorizontalAlignment="Left"
            Click="Return_Button_Click"/>

            <TextBlock x:Name="ScoreText"
               Text="Victoires : 0"
               FontSize="22"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0,10,0,0"/>

            <TextBlock x:Name="StatusText"
               Text="Votre tour (X)"
               FontSize="18"
               HorizontalAlignment="Center"
               Margin="0,10,0,0"/>

        </StackPanel>

        <Grid x:Name="GameGrid">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="0" Grid.Column="1" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="0" Grid.Column="2" Click="Cell_Click" FontSize="40"/>

            <Button Grid.Row="1" Grid.Column="0" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="1" Grid.Column="1" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="1" Grid.Column="2" Click="Cell_Click" FontSize="40"/>

            <Button Grid.Row="2" Grid.Column="0" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="2" Grid.Column="1" Click="Cell_Click" FontSize="40"/>
            <Button Grid.Row="2" Grid.Column="2" Click="Cell_Click" FontSize="40"/>

        </Grid>

    </DockPanel>
</Page>