<Page x:Class="Brainrot_idle.view.ParametreFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ParametreFrame">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Grid.Column="3" Content="Fermer" Margin="100,5,5,5" Click="Close_Button_Click"/>
        <!--volume-->
        <Slider x:Name="VolumeSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="100" Margin="50,50,50,5"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Volume" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="50,0,10,-20"/>
        <Label Grid.Row="1" Grid.Column="0" Content="{Binding ElementName=VolumeSlider, Path=Value}" ContentStringFormat="{}{0:0}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,50,-20"/>
        <!--2nd parametre-->
    </Grid>
</Page>
