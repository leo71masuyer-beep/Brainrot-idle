<Page x:Class="Brainrot_idle.view.SkillTreeFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1100"
      Title="SkillTreeFrame">

    <Page.Resources>
        <Style x:Key="RoundSkillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="95"/>
            <Setter Property="Height" Value="95"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BackgroundEllipse" Fill="#120524" Stroke="#9D00FF" StrokeThickness="3"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#2A004D"/>
                                <Setter TargetName="BackgroundEllipse" Property="Stroke" Value="#00FF40"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#4A00E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#4D0099"/>
            <Setter Property="StrokeThickness" Value="4"/>
        </Style>

        <Style x:Key="PriceLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Page.Resources>

    <Grid Background="#0A0410">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10" Margin="15,15,15,5">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← RETOUR" Background="#2A004D" Foreground="White" 
                        BorderBrush="#9D00FF" BorderThickness="2" FontWeight="Bold" Padding="15,8" 
                        VerticalAlignment="Center" Cursor="Hand"
                        Click="Close_Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ARBRE DE COMPÉTENCES" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TextePointsDispo" 
                               Text="Points disponibles : 0" 
                               FontSize="14" FontWeight="Bold" Foreground="#00FF40"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Column="2" VerticalAlignment="Center" Width="220">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="TexteNiveau" Text="Niveau : 1" FontWeight="Bold" Foreground="#00FF40" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="0" x:Name="TexteXp" Text="0 / 10 XP" FontSize="10" FontWeight="Bold" Foreground="#D0C0E0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2"/>

                    <ProgressBar Grid.Row="1" x:Name="BarreXp" Height="8" Background="#0A0410" BorderBrush="#9D00FF" Foreground="#00FF40" Minimum="0" Margin="0,4,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="15,5">
            <Border BorderBrush="#9D00FF" BorderThickness="3" Background="#120524" CornerRadius="10">
                <Canvas Width="1000" Height="620" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,10">

                    <Line Style="{StaticResource TreeLineStyle}" X1="350" Y1="95" X2="200" Y2="245"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="350" Y1="95" X2="370" Y2="245"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="650" Y1="95" X2="630" Y2="245"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="650" Y1="95" X2="800" Y2="245"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="200" Y1="245" X2="230" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="370" Y1="245" X2="230" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="370" Y1="245" X2="500" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="630" Y1="245" X2="500" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="630" Y1="245" X2="770" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="800" Y1="245" X2="770" Y2="395"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="230" Y1="395" X2="500" Y2="545"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="500" Y1="395" X2="500" Y2="545"/>
                    <Line Style="{StaticResource TreeLineStyle}" X1="770" Y1="395" X2="500" Y2="545"/>

                    <StackPanel Canvas.Left="302.5" Canvas.Top="47.5" Width="95">
                        <Button x:Name="BtnApprenti" Content="Apprenti" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="multiplicateur de 50%" Click="Apprenti_Click"/>
                        <TextBlock x:Name="LblPrixApprenti" Text="Prix : 1 Pt" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="602.5" Canvas.Top="47.5" Width="95">
                        <Button x:Name="BtnCliqueur" Content="Cliqueur" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Valeur clique x1.5" Click="Cliqueur_Click"/>
                        <TextBlock x:Name="LblPrixCliqueur" Text="Prix : 1 Pt" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="152.5" Canvas.Top="197.5" Width="95">
                        <Button Content="Jeu de combat" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu de combat" Click="JeuDeCombat_Click"/>
                        <TextBlock x:Name="LblPrixCombat" Text="Prix : 2 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="322.5" Canvas.Top="197.5" Width="95">
                        <Button Content="morpion" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu morpion" Click="Morpion_Click"/>
                        <TextBlock x:Name="LblPrixMorpion" Text="Prix : 2 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="582.5" Canvas.Top="197.5" Width="95">
                        <Button Content="Jeu 4" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu 4" Click="Jeu4_Click"/>
                        <TextBlock x:Name="LblPrixJeu4" Text="Prix : 2 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="752.5" Canvas.Top="197.5" Width="95">
                        <Button Content="Jeu 5" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu 5" Click="Jeu5_Click"/>
                        <TextBlock x:Name="LblPrixJeu5" Text="Prix : 2 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="182.5" Canvas.Top="347.5" Width="95">
                        <Button Content="Jeu 6" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu 6" Click="Jeu6_Click"/>
                        <TextBlock x:Name="LblPrixJeu6" Text="Prix : 3 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="452.5" Canvas.Top="347.5" Width="95">
                        <Button Content="Jeu 7" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu 7" Click="Jeu7_Click"/>
                        <TextBlock x:Name="LblPrixJeu7" Text="Prix : 3 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="722.5" Canvas.Top="347.5" Width="95">
                        <Button Content="Snake" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le Snake" Click="Snake_Click"/>
                        <TextBlock x:Name="LblPrixSnake" Text="Prix : 3 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                    <StackPanel Canvas.Left="452.5" Canvas.Top="497.5" Width="95">
                        <Button Content="Jeu 8" Style="{StaticResource RoundSkillButtonStyle}" ToolTip="Débloque le jeu 8" Click="Jeu8_Click"/>
                        <TextBlock x:Name="LblPrixJeu8" Text="Prix : 5 Pts" Style="{StaticResource PriceLabelStyle}"/>
                    </StackPanel>

                </Canvas>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,5,0,15">
            <Button Content="+1 XP" 
                    Width="180" Height="45"
                    FontWeight="Bold" FontSize="16"
                    Background="#9D00FF" 
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Cursor="Hand"
                    Click="XpButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="BorderBrush" Value="#00FF40"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Page>