<Page x:Class="Brainrot_idle.view.SkillTreeFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SkillTreeFrame">

    <Page.Resources>
        <Style x:Key="SkillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center" Margin="50">

            <TextBlock Text="Arbre de Compétences" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Retour" VerticalAlignment="Top" HorizontalAlignment="Left" Click="Close_Button_Click"/>

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Plus d'aura" FontSize="18" Foreground="Gray"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Logique" 
                Style="{StaticResource SkillButtonStyle}" 
                ToolTip="Génère 1 point/sec automatiquement."/>
                    <Button Content="Synthèse" 
                Style="{StaticResource SkillButtonStyle}" 
                ToolTip="Améliore l'efficacité globale de 10%."/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Spécialisation (Niveau 2)" FontSize="18" Foreground="Gray"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Analyse" 
                Style="{StaticResource SkillButtonStyle}" 
                ToolTip="Débloque le multiplicateur x2 sur les gains."/>
                    <Button Content="Stratégie" 
                Style="{StaticResource SkillButtonStyle}" 
                ToolTip="Réduit le coût des prochaines améliorations."/>
                    <Button Content="Gestion" 
                Style="{StaticResource SkillButtonStyle}" 
                ToolTip="Augmente la limite de stockage des points."/>
                </StackPanel>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Maîtrise (Niveau 3)" FontSize="18" Foreground="Gray"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Expertise" Style="{StaticResource SkillButtonStyle}"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
