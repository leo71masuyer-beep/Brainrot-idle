<Page x:Class="Brainrot_idle.view.SkillTreeFrame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1100"
      Title="SkillTreeFrame">

    <Page.Resources>
        <Style x:Key="RoundSkillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="95"/>
            <Setter Property="Height" Value="95"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BackgroundEllipse" Fill="#EBF0F6" Stroke="#34495E" StrokeThickness="2.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#D2D7DF"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundEllipse" Property="Fill" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeLineStyle" TargetType="Line">
            <Setter Property="Stroke" Value="#BDC3C7"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
    </Page.Resources>

    <Grid Background="#F4F6F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="30,20,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Retour" 
                    VerticalAlignment="Center" 
                    Padding="12,6"
                    Click="Close_Button_Click"/>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Arbre de Compétences" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TextePointsDispo" 
                           Text="Points disponibles : 0" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#27AE60"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock x:Name="TexteNiveau" Text="Niveau : 1" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Right"/>
                    <ProgressBar x:Name="BarreXp" Width="150" Height="14" Margin="0,4,0,0" Minimum="0"/>
                    <TextBlock x:Name="TexteXp" Text="0 / 10 XP" FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Content="+1 XP" 
                        Padding="15,10" 
                        FontWeight="Bold"
                        Background="#9B59B6" 
                        Foreground="White"
                        Click="XpButton_Click"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas Width="1000" Height="650" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,20">

                <Line Style="{StaticResource TreeLineStyle}" X1="350" Y1="95" X2="200" Y2="245"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="350" Y1="95" X2="370" Y2="245"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="650" Y1="95" X2="630" Y2="245"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="650" Y1="95" X2="800" Y2="245"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="200" Y1="245" X2="230" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="370" Y1="245" X2="230" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="370" Y1="245" X2="500" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="630" Y1="245" X2="500" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="630" Y1="245" X2="770" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="800" Y1="245" X2="770" Y2="395"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="230" Y1="395" X2="500" Y2="545"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="500" Y1="395" X2="500" Y2="545"/>
                <Line Style="{StaticResource TreeLineStyle}" X1="770" Y1="395" X2="500" Y2="545"/>

                <Button Content="Apprenti" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="300" Canvas.Top="50"
                        ToolTip="Génère 1 point/sec automatiquement."
                        Click="Apprenti_Click"/>

                <Button Content="Cliqueur" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="600" Canvas.Top="50"
                        ToolTip="Améliore l'efficacité globale de 10%."
                        Click="Cliqueur_Click"/>

                <Button Content="Jeu de combat" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="150" Canvas.Top="200"
                        ToolTip="Débloque le multiplicateur x2 sur les gains."
                        Click="JeuDeCombat_Click"/>

                <Button Content="Jeu 3" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="320" Canvas.Top="200"
                        ToolTip="Réduit le coût des prochaines améliorations."
                        Click="Jeu3_Click"/>

                <Button Content="Jeu 4" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="580" Canvas.Top="200"
                        ToolTip="Augmente la limite de stockage des points."
                        Click="Jeu4_Click"/>

                <Button Content="Jeu 5" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="750" Canvas.Top="200"
                        ToolTip="Augmente la vitesse de production de 15%."
                        Click="Jeu5_Click"/>

                <Button Content="Jeu 6" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="180" Canvas.Top="350"
                        ToolTip="Multiplie les gains passifs par le nombre de compétences débloquées."
                        Click="Jeu6_Click"/>

                <Button Content="Multiplicateur" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="450" Canvas.Top="350"
                        ToolTip="Fusionne les bonus de Stratégie et Gestion (+25%)."
                        Click="Multiplicateur_Click"/>

                <Button Content="Boost 1" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="720" Canvas.Top="350"
                        ToolTip="Achète automatiquement les améliorations les moins chères."
                        Click="Boost1_Click"/>

                <Button Content="Boost 2" 
                        Style="{StaticResource RoundSkillButtonStyle}" 
                        Canvas.Left="450" Canvas.Top="500"
                        ToolTip="Multiplie l'Aura globale par 5. Fin de l'arbre."
                        Click="Boost2_Click"/>

            </Canvas>
        </ScrollViewer>
    </Grid>
</Page>