<Page x:Class="Brainrot_idle.view.Snake"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d"
      KeyDown="Page_KeyDown"
      Focusable="True">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button x:Name="BoutonRetour"
                Grid.Row="0"
                Content="Retour"
                Width="100"
                Height="30"
                Margin="10"
                HorizontalAlignment="Left"
                Click="Return_Button_Click"/>

        <TextBlock x:Name="TexteScore"
                   Grid.Row="1"
                   Text="Score : 0"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="10"
                   VerticalAlignment="Center"/>

        <Border Grid.Row="2"
                Margin="10"
                BorderBrush="Black"
                BorderThickness="2">

            <Canvas x:Name="ZoneDeJeu"
                    Background="LightGray"
                    Width="800"
                    Height="600"/>

        </Border>

    </Grid>

</Page>