        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Brainrot_idle.view"
        mc:Ignorable="d">
    <Grid>
        
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TexteScore" Text="Score: 0" Foreground="Black" FontSize="24" FontWeight="Bold" Margin="10,0"/>

            <Canvas x:Name="ZoneDeJeu" Grid.Row="1" Background="LightGray"/>
        
    </Grid>
</Page>
