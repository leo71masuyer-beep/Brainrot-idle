<Page x:Class="Brainrot_idle.view.StatistiquesFrames"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Brainrot_idle.view"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StatistiquesFrames">

    <Grid Background="#090014">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A0028" BorderBrush="#7A00FF" BorderThickness="2" CornerRadius="15" Margin="10,20" Padding="15">
            <StackPanel>
                <TextBlock Text="ÉCONOMIE" Foreground="#CCFF00" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock x:Name="TxtPoints" Text="Points : 0" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtAuraSec" Text="Aura/s : 0" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtClicsSec" Text="Clics/s : 0" Foreground="White" FontSize="16" Margin="0,10"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#1A0028" BorderBrush="#7A00FF" BorderThickness="2" CornerRadius="15" Margin="10,20" Padding="15">
            <StackPanel>
                <TextBlock Text="PROGRESSION" Foreground="#CCFF00" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock x:Name="TxtNiveau" Text="Niveau : 1" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtXp" Text="XP : 0 / 10" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtPointsComp" Text="Points de comp. : 0" Foreground="White" FontSize="16" Margin="0,10"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="#1A0028" BorderBrush="#7A00FF" BorderThickness="2" CornerRadius="15" Margin="10,20" Padding="15">
            <StackPanel>
                <TextBlock Text="DIVERS" Foreground="#CCFF00" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock x:Name="TxtScoreSnake" Text="Record Snake : 0" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtMultXp" Text="Mult. XP : x1.0" Foreground="White" FontSize="16" Margin="0,10"/>
                <TextBlock x:Name="TxtMultAura" Text="Mult. Aura/Clic : x1.0" Foreground="White" FontSize="16" Margin="0,10"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>